    "components": [
      {
        "weight": 0.7,
        "distribution": {
          "type": "normal",
          "mean": 220,
          "stddev": 80,
          "min": 16,
          "max": 1024
        }
      },
      {
        "weight": 0.3,
        "distribution": {
          "type": "uniform",
          "min": 4000,
          "max": 12000
        }
      }
    ]
  },
  "output_length_distribution": {
    "type": "mixture",
    "components": [
      {
        "weight": 0.7,
        "distribution": {
          "type": "lognormal",
          "mu": 5.0,
          "sigma": 0.6,
          "min": 8,
          "max": 512
        }
      },
      {
        "weight": 0.3,
        "distribution": {
          "type": "normal",
          "mean": 250,
          "stddev": 100,
          "min": 32,
          "max": 768
        }
      }
    ]
