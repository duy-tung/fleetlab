{
  "name": "mixed",
  "version": "0.1.0",
  "seed": 20260710,
  "description": "Mixture of chat-like (70%) and RAG-like (30%) traffic via mixture length distributions. NON-NORMATIVE example fixture; canonical suite owned by inferbench.",
  "arrival_process": {
    "type": "open-loop-poisson",
